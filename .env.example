# ─────────────────────────────────────────────────
#  .env.example  →  .env 로 복사 후 값을 채워주세요
# ─────────────────────────────────────────────────

# [필수] 디스코드 봇 토큰
# Discord Developer Portal → Bot → Token 에서 복사
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# [선택] SQLite DB 파일 경로 (기본: data/dsu_myteam.db)
DATABASE_PATH=data/dsu_myteam.db

# [선택] 구글 시트 연동
# Google Cloud Console → 서비스 계정 생성 → JSON 키 다운로드 → credentials.json으로 저장
GSHEET_CREDENTIALS=credentials.json
# 스프레드시트 URL에서 /d/XXXXXXX/edit 부분의 XXXXXXX
GSHEET_SPREADSHEET_ID=YOUR_SPREADSHEET_ID_HERE
GSHEET_WORKSHEET_NAME=활동목록

# [선택] Gemini AI 매칭 리포트
# Google AI Studio → API 키 생성
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
